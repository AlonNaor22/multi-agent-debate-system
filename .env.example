# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides (defaults shown; see config.py for the full list).
# LLM call resilience — seconds per request, and how many times the Anthropic
# SDK retries transient failures (429 / 5xx / connection) before giving up.
# REQUEST_TIMEOUT=60.0
# MAX_RETRIES=2
